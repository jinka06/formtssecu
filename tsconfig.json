{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "outDir": "./frontend/dist",
    "rootDir": "./frontend",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["frontend/**/*", "backend/types/express.d.ts"],
  "exclude": ["node_modules", "backend"]
}
